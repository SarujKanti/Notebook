<?xml version="1.0" encoding="utf-8"?>
<!-- App logo — same folder design used in the adaptive icon foreground.
     Shown at ~100 dp on the splash screen; no dark background included here
     so it renders correctly on any background colour. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="96dp"
    android:height="96dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Back: bright green right panel -->
    <path
        android:fillColor="#00D68F"
        android:pathData="M 55,20 L 98,28 L 92,84 L 48,76 Z"/>

    <!-- White document edge -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 46,13 L 88,19 Q 90,20 90,22 L 88,27 L 45,21 Q 43,20 44,17 Z"/>

    <!-- Blue-purple center triangle -->
    <path
        android:fillColor="#6C5CE7"
        android:pathData="M 57,26 L 86,52 L 62,82 Z"/>

    <!-- Front: teal folder face -->
    <path
        android:fillColor="#00BFA5"
        android:pathData="M 10,22 L 62,16 L 60,84 L 6,84 Z"/>

    <!-- Diagonal //// lines -->
    <path android:strokeColor="#FFFFFF" android:strokeWidth="4.5"
        android:strokeLineCap="round" android:fillColor="#00000000"
        android:pathData="M 22,58 L 48,30"/>
    <path android:strokeColor="#FFFFFF" android:strokeWidth="4.5"
        android:strokeLineCap="round" android:fillColor="#00000000"
        android:pathData="M 24,66 L 52,38"/>
    <path android:strokeColor="#FFFFFF" android:strokeWidth="4.5"
        android:strokeLineCap="round" android:fillColor="#00000000"
        android:pathData="M 26,74 L 52,48"/>
    <path android:strokeColor="#FFFFFF" android:strokeWidth="4.5"
        android:strokeLineCap="round" android:fillColor="#00000000"
        android:pathData="M 22,78 L 44,58"/>

    <!-- White dot -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 28,26 m -4,0 a 4,4 0 1,0 8,0 a 4,4 0 1,0 -8,0"/>

</vector>
